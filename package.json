{
  "name": "champ-sage",
  "private": true,
  "author": "Mark Lozano",
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build": "tsc && vite build",
    "audit-augments": "tsx scripts/audit-augments.ts",
    "build:electron": "tsup --config electron/tsup.config.ts && vite build",
    "check-game": "tsx scripts/check-game.ts",
    "convert-fixtures": "tsx scripts/convert-fixtures-multiturn.ts",
    "dev": "vite",
    "dev:electron": "tsup --config electron/tsup.config.ts && concurrently -k \"vite\" \"scripts/launch-electron.sh\"",
    "discover-candidates": "tsx scripts/discover-candidates.ts",
    "eval": "evalite src/lib/ai/coaching.eval.ts",
    "eval:serve": "evalite serve",
    "eval:watch": "evalite watch src/lib/ai/coaching.eval.ts",
    "extract-fixtures": "tsx scripts/extract-fixtures.ts",
    "inspect-evals": "tsx scripts/inspect-evals.ts",
    "lcu-monitor": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx scripts/lcu-monitor.ts",
    "prepare": "husky",
    "preview": "vite preview",
    "start:electron": "ow-electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.134",
    "deep-object-diff": "^1.1.9",
    "electron-log": "^5.4.3",
    "luaparse": "^0.3.1",
    "openai": "^6.32.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rxjs": "^7.8.2"
  },
  "overwolf": {
    "packages": [
      "gep",
      "overlay"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@overwolf/ow-electron": "^39.6.1",
    "@overwolf/ow-electron-builder": "^26.8.3",
    "@overwolf/ow-electron-packages-types": "^1.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luaparse": "^0.2.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "evalite": "^0.19.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "pickai": "^2.1.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.2",
    "ws": "^8.19.0"
  }
}
