{
  "name": "champ-sage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:watch": "vitest",
    "check-game": "tsx scripts/check-game.ts",
    "lcu-monitor": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx scripts/lcu-monitor.ts",
    "discover-candidates": "tsx scripts/discover-candidates.ts",
    "audit-augments": "tsx scripts/audit-augments.ts",
    "preview-prompts": "tsx scripts/preview-prompts.ts",
    "extract-fixtures": "tsx scripts/extract-fixtures.ts",
    "eval": "evalite src/lib/ai/coaching.eval.ts",
    "eval:watch": "evalite watch src/lib/ai/coaching.eval.ts",
    "eval:serve": "evalite serve",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "ai": "^6.0.134",
    "deep-object-diff": "^1.1.9",
    "luaparse": "^0.3.1",
    "openai": "^6.32.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rxjs": "^7.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/luaparse": "^0.2.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "dotenv": "^17.3.1",
    "evalite": "^0.19.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "pickai": "^2.1.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "ws": "^8.19.0"
  }
}
